<Page x:Class="Konditerka.Pages.Authoriz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Konditerka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Вход">

    <Grid Background="#FF213A2F">
        <Label Content="Вход в лавку гномиков" HorizontalAlignment="Center" Margin="0,28,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FFF7E1A1" FontSize="30"/>
        <Label Content="Введите логин" HorizontalAlignment="Center" Margin="-100,120,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FFF7E1A1" FontSize="20"/>
        <TextBox x:Name="LoginBox" HorizontalAlignment="Center" Margin="0,156,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="LoginBox" TabIndex="50" FontFamily="Arial Black"/>
        <Label Content="Введите пароль" HorizontalAlignment="Center" Margin="-90,197,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FFF7E1A1" FontSize="20"/>
        <PasswordBox x:Name="PassBox" HorizontalAlignment="Center" Margin="0,230,0,0" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="PassBox" TabIndex="50" FontFamily="Arial Black"/>
        <Button x:Name="LoginButton" Content="Войти" HorizontalAlignment="Center" Margin="0,307,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Arial Black" FontSize="16" Background="#FFF7E1A1" Foreground="Black" Click="LoginButton_Click"/>
        <Button x:Name="OpenRegButton" Content="Регистрация" HorizontalAlignment="Center" Margin="0,349,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Arial Black" FontSize="16" Background="#FFF7E1A1" Foreground="Black" Click="OpenRegButton_Click"/>

    </Grid>
</Page>
